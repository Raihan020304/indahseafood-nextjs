# ============================================
# SUPABASE
# Ambil dari: Supabase Dashboard > Project Settings > API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-RAHASIA-jangan-expose-ke-client

# ============================================
# MIDTRANS
# Daftar di https://dashboard.midtrans.com (mode Sandbox untuk testing)
# Ambil dari: Settings > Access Keys
# ============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ============================================
# AUTH (untuk session admin - JWT)
# Generate string acak panjang, contoh: openssl rand -base64 32
# ============================================
JWT_SECRET=ganti-dengan-string-rahasia-yang-sangat-panjang-dan-acak

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
